{
  "manifest_version": 3,
  "name": "Tamil AI Dub",
  "version": "1.0",
  "description": "Converts English video subtitles into Tamil dubbing in real-time.",
  "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "icons": {
    "16": "image.png",
    "48": "image.png",
    "128": "image.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": "image.png"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content_script.js"],
      "run_at": "document_idle"
    }
  ]
}